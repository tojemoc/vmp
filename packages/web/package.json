{
  "name": "@vmp/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint . --ext .ts,.vue,.tsx --max-warnings 0",
    "build:sw-push": "tsc --ignoreConfig sw-push.ts --target ES2022 --module ES2020 --lib ES2022,WebWorker --skipLibCheck --outDir public --removeComments",
    "build:sw-offline": "tsc --ignoreConfig sw-offline-media.ts --target ES2022 --module ES2020 --lib ES2022,WebWorker --skipLibCheck --outDir public --removeComments",
    "build:sw-scripts": "npm run build:sw-push && npm run build:sw-offline",
    "typecheck:scripts": "tsc --ignoreConfig --noEmit sw-push.ts scripts/gen-icons.ts tailwind.config.ts --target ES2022 --module ES2020 --moduleResolution bundler --skipLibCheck --types node --lib ES2022,WebWorker && tsc --ignoreConfig --noEmit sw-offline-media.ts --target ES2022 --module ES2020 --moduleResolution bundler --skipLibCheck --types node --lib ES2022,WebWorker",
    "predev": "npm run build:sw-scripts",
    "prebuild": "npm run build:sw-scripts",
    "predeploy": "npm run build:sw-scripts",
    "dev": "nuxi dev",
    "build": "nuxi build --preset=cloudflare-module",
    "build:pages": "nuxi build --preset=cloudflare_pages",
    "generate": "nuxi generate",
    "preview": "nuxi preview",
    "preview:workers": "wrangler dev --config wrangler.workers.toml",
    "typecheck": "nuxi prepare && nuxi typecheck",
    "deploy": "wrangler deploy --config wrangler.workers.toml",
    "deploy:prod": "wrangler deploy --config wrangler.workers.toml --env=production",
    "gen:icons": "tsx scripts/gen-icons.ts"
  },
  "dependencies": {
    "@moq/net": "^0.1.9",
    "@moq/watch": "^0.3.2",
    "@nuxtjs/color-mode": "^4.0.0",
    "@sentry/nuxt": "^10.66.0",
    "@stripe/stripe-js": "^9.10.0",
    "@tiptap/core": "^3.28.0",
    "@tiptap/extension-link": "^3.28.0",
    "@tiptap/extension-placeholder": "^3.28.0",
    "@tiptap/html": "^3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "@tiptap/vue-3": "^3.28.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vmp/shared": "*",
    "media-chrome": "^4.19.0",
    "nuxt": "^4.5.0",
    "qrcode": "^1.5.4",
    "tus-js-client": "^4.3.1",
    "unsane": "^0.0.19",
    "video.js": "^8.23.9",
    "videojs-video-element": "^1.4.8",
    "vue": "^3.5.40"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vue-tsc": "^3.3.7",
    "wrangler": "^4.112.0"
  },
  "nx": {
    "targets": {
      "deploy": {
        "dependsOn": [
          "^deploy"
        ]
      }
    }
  }
}
