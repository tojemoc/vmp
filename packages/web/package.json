{
  "name": "@vmp/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint . --ext .ts,.vue,.tsx --max-warnings 0",
    "build:sw-push": "tsc --ignoreConfig sw-push.ts --target ES2022 --module ES2020 --lib ES2022,WebWorker --skipLibCheck --outDir public --removeComments",
    "typecheck:scripts": "tsc --ignoreConfig --noEmit sw-push.ts scripts/gen-icons.ts tailwind.config.ts --target ES2022 --module ES2020 --moduleResolution bundler --skipLibCheck --types node --lib ES2022,WebWorker",
    "predev": "npm run build:sw-push",
    "prebuild": "npm run build:sw-push",
    "predeploy": "npm run build:sw-push",
    "dev": "nuxi dev",
    "build": "nuxi build --preset=cloudflare_pages",
    "build:workers": "nuxi build --preset=cloudflare-module",
    "generate": "nuxi generate",
    "preview": "nuxi preview",
    "preview:workers": "wrangler dev --config wrangler.workers.toml",
    "typecheck": "nuxi prepare && nuxi typecheck",
    "deploy": "node scripts/deploy-pages.mjs",
    "deploy:workers": "wrangler deploy --config wrangler.workers.toml --env=\"\"",
    "deploy:workers:prod": "wrangler deploy --config wrangler.workers.toml --env=production",
    "gen:icons": "tsx scripts/gen-icons.ts"
  },
  "dependencies": {
    "@moq/net": "^0.1.5",
    "@moq/watch": "^0.2.16",
    "@nuxtjs/color-mode": "^4.0.0",
    "@sentry/nuxt": "^10.57.0",
    "@stripe/stripe-js": "^9.8.0",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/html": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/vue-3": "^3.27.1",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vmp/shared": "*",
    "isomorphic-dompurify": "^3.18.0",
    "media-chrome": "^4.19.0",
    "nuxt": "^4.4.8",
    "qrcode": "^1.5.4",
    "tus-js-client": "^4.3.1",
    "video.js": "^8.23.7",
    "videojs-video-element": "^1.4.8",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@saslavik/nuxt-gtm": "^0.1.3",
    "@types/node": "^25.9.3",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.4",
    "wrangler": "^4.102.0"
  },
  "nx": {
    "targets": {
      "deploy": {
        "dependsOn": [
          "build",
          "^deploy"
        ]
      }
    }
  }
}
