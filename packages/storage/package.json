{
  "name": "@vmp/storage",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Pluggable object storage providers (R2, B2, S3-compatible)",
  "exports": {
    ".": "./src/index.ts",
    "./worker": "./src/worker.ts",
    "./node": "./src/node.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test ./test/*.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1080.0",
