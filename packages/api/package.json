{
  "name": "@vmp/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "VMP API - Cloudflare Workers with D1",
  "main": "src/index.ts",
  "scripts": {
    "test": "tsx --test ./test/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 execute video-subscription-db --file=./migrations/0001_canonical_schema.sql",
    "db:seed": "wrangler d1 execute video-subscription-db --file=./migrations/0002_canonical_seed.sql",
    "db:teardown": "wrangler d1 execute video-subscription-db --file=./scripts/db_teardown.sql",
    "db:reset": "npm run db:teardown && npm run db:create && npm run db:seed",
    "db:migration-backfill": "bash ./scripts/migration_backfill_and_mapping.sh",
    "db:migration-verify": "bash ./scripts/migration_integrity_check.sh"
  },
  "dependencies": {
    "@vmp/shared": "*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260414.1",
    "@types/node": "^25.6.0",
    "tsx": "^4.20.6",
    "wrangler": "^4.82.2"
  }
}