{
  "name": "@vmp/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "VMP API - Cloudflare Workers with D1",
  "main": "src/index.js",
  "scripts": {
    "test": "node --test ./test/*.test.js",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 execute video-subscription-db --file=./migrations/0001_canonical_schema.sql",
    "db:seed": "wrangler d1 execute video-subscription-db --file=./migrations/0002_canonical_seed.sql",
    "db:teardown": "wrangler d1 execute video-subscription-db --file=./scripts/db_teardown.sql",
    "db:reset": "npm run db:teardown && npm run db:create && npm run db:seed"
  },
  "dependencies": {
    "@vmp/shared": "*"
  },
  "devDependencies": {
    "wrangler": "^4.81.0"
  }
}