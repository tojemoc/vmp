{
  "name": "@vmp/offloading",
  "version": "1.0.0",
  "private": true,
  "description": "R2 to Garage hot/cold storage offloading jobs",
  "type": "module",
  "scripts": {
    "lint": "eslint src --ext .ts,.vue,.tsx --max-warnings 0",
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && node ./dist/index.js",
    "demote": "npm run build && node ./dist/index.js demote",
    "promote": "npm run build && node ./dist/index.js promote",
    "trigger-promote": "npm run build && node ./dist/index.js trigger-promote"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
