# Copy to encore/.env (or point VMP_ENV_FILE at /etc/vmp/env) before `docker compose up`.
# Required for vmp-supervisor — see packages/media-pipeline/README.md for the full list.

VMP_WEBHOOK_SECRET=replace-with-d1-podcast_rebuild_webhook_secret
# URL-safe only (letters/digits/_/-) — embedded in encore-packager CALLBACK_URL Basic auth
VMP_PACKAGER_SECRET=replace-with-long-random-string
VMP_SUPERVISOR_DASHBOARD_SECRET=replace-with-long-random-string

VMP_API_BASE_URL=https://api.example.com
VMP_API_PIPELINE_SECRET=replace-with-worker-pipeline-secret

# R2 via encore-packager (required for packaging stage — empty keys leave jobs stuck at "packaging queued")
PACKAGE_OUTPUT_FOLDER=s3://your-bucket/videos
S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto
# Optional override (default embeds VMP_PACKAGER_SECRET as Basic auth password):
# PACKAGER_CALLBACK_URL=http://vmp:YOUR_PACKAGER_SECRET@vmp-supervisor:8788/vmp/api

# Host bind for dashboard + Worker webhooks (default loopback-only)
# VMP_UI_BIND=127.0.0.1:8788
# VMP_UI_BIND=0.0.0.0:8788

# TrueNAS / NFS mapall — run media containers as that UID:GID
# MEDIA_USER=3000:3000
# Then: docker compose -f docker-compose.yml -f docker-compose.nfs.yml up -d

# Pin a specific GHCR build instead of :latest
# VMP_SUPERVISOR_IMAGE=ghcr.io/tojemoc/vmp-media-pipeline:sha-abc1234
