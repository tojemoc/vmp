{
  "name": "@vmp/podcast-host",
  "version": "1.0.0",
  "private": true,
  "description": "VM media host: HLS/podcast pipeline (watchfolder), preview MP3 webhook, local dashboard",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && node ./dist/supervisor.js",
    "supervisor": "npm run build && node ./dist/supervisor.js",
    "pipeline": "npm run build && node ./dist/pipeline_watch.js",
    "migrate:r2-video-prefixes": "bash ./bin/video_id_r2_prefix_migrate.sh",
    "render": "npm run build && node ./dist/render_podcast_preview_mp3.js"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
