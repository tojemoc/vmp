{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
  "name": "@vmp/api-node",
  "version": "1.0.0",
  "exports": {
    ".": "./src/server.ts"
  },
  "deploy": {
    "install": "NX_SKIP_POSTINSTALL=1 npm --prefix ../.. run install:api-node",
    "build": "npm --prefix ../.. run build:api-node",
    "runtime": {
      "type": "dynamic",
      "entrypoint": "./dist/server.js",
      "cwd": "."
    }
  }
}
