{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
  "name": "@vmp/api-node",
  "version": "1.0.0",
  "exports": {
    ".": "./dist/server.js"
  },
  "deploy": {
    "install": "npm ci",
    "build": "npm run build",
    "runtime": {
      "type": "dynamic",
      "entrypoint": "./dist/server.js",
      "cwd": "."
    }
  }
}
