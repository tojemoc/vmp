{
  "name": "@vmp/api-node",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "VMP API failover node server (D1/S3/KV adapters for @vmp/api Worker code)",
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "node dist/server.js",
    "sync:now": "node dist/sync/d1sync-cli.js --once",
    "sync:write-log-export": "node dist/sync/write-log-export-cli.js",
    "dev": "npm run build && node --watch dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vmp/api": "1.0.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "better-sqlite3": "^9.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.5.0"
  }
}
