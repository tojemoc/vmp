{
  "name": "@vmp/api-node",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "description": "VMP API on Deno Deploy (Postgres D1 shim, S3/R2, SQL-backed KV for @vmp/api Worker code)",
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "node dist/server.js",
    "dev": "npm run build && node --watch dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": "^22.12.0 || ^24.11.0 || >=26.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1071.0",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260604.1",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  }
}
