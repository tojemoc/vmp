{
  "name": "@vmp/api-node",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "description": "VMP API on Deno Deploy (Postgres D1 shim, S3/R2, SQL-backed KV for @vmp/api Worker code)",
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "node dist/server.js",
    "dev": "npm run build && node --watch dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/*.test.ts",
    "verify:deploy": "npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": "^22.12.0 || ^24.11.0 || >=26.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1080.0",
    "@vmp/storage": "*",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@sentry/cloudflare": "^10.63.0",
    "@types/node": "^26.1.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
