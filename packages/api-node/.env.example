# ── Server ────────────────────────────────────────────────────────────────────
PORT=8787
NODE_ENV=development
HEALTH_S3_TIMEOUT_MS=5000

# Deno Deploy injects DATABASE_URL per context (local / preview / production).
# For local dev, point at Postgres (e.g. Prisma Postgres tunnel or docker postgres).
DATABASE_URL=postgresql://user:password@localhost:5432/vmp_dev
# Optional pool size (keep low on serverless)
# DATABASE_POOL_SIZE=5
# Set to 0 to skip automatic migration application at boot
# RUN_MIGRATIONS=1
# Set to 0 to disable optional SQL write audit log table
# ENABLE_WRITE_LOG=1

# ── Auth / crypto (required — same values as Cloudflare Worker secrets) ───────
JWT_SECRET=
TOTP_ENCRYPTION_KEY=
RSS_SECRET=

# ── Email / payments / push ───────────────────────────────────────────────────
BREVO_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
GOCARDLESS_ACCESS_TOKEN=
GOCARDLESS_CREDITOR_ID=
GOCARDLESS_WEBHOOK_SECRET=

# ── App URLs / CORS ───────────────────────────────────────────────────────────
FRONTEND_URL=https://vmp.example.com
ALLOWED_ORIGINS=https://vmp.example.com,http://localhost:3000
R2_BASE_URL=https://videos.example.com
SENDER_EMAIL=vmp@example.com
SENDER_NAME=VMP
STRIPE_PUBLISHABLE_KEY=

# ── S3 bucket (MediaConvert output — same assets as R2 in production) ───────
S3_BUCKET_NAME=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional custom endpoint (MinIO, etc.)
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=1

# ── D1 → Postgres replication ingest (Cloudflare Queue consumer POSTs here) ─
# Same secret as Worker REPLICATION_TARGET_TOKEN. Set REPLICATION_TARGET_URL on
# the Cloudflare Worker to https://<deno-host>/api/internal/replication/ingest
REPLICATION_INGEST_TOKEN=

# ── Optional R2 → S3 manifest sync (m3u8 only) ───────────────────────────────
# R2_S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=

# ── MediaConvert vars (optional, if admin transcode UI is used) ─────────────
MEDIA_CONVERT_ENABLED=0
MEDIA_CONVERT_INPUT_PREFIX=mediaconvert-input
MEDIA_CONVERT_OUTPUT_PREFIX=mediaconvert-output
MEDIA_CONVERT_MAX_UPLOAD_MB=4096
MEDIA_CONVERT_PRICE_HD_PER_MIN=0.015
