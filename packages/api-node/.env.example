# ── Server ────────────────────────────────────────────────────────────────────
PORT=8787
SQLITE_DB_PATH=./data/vmp.sqlite
NODE_ENV=development
D1_SYNC_INTERVAL_MS=300000
D1_SYNC_STATE_PATH=./data/d1-sync-state.json

# ── Auth / crypto (required — same values as Cloudflare Worker secrets) ───────
JWT_SECRET=
TOTP_ENCRYPTION_KEY=
RSS_SECRET=

# ── Email / payments / push ───────────────────────────────────────────────────
BREVO_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
GOCARDLESS_ACCESS_TOKEN=
GOCARDLESS_WEBHOOK_SECRET=

# ── App URLs / CORS ───────────────────────────────────────────────────────────
FRONTEND_URL=https://vmp.example.com
ALLOWED_ORIGINS=https://vmp.example.com,http://localhost:3000
R2_BASE_URL=https://videos.example.com
SENDER_EMAIL=vmp@example.com
SENDER_NAME=VMP
STRIPE_PUBLISHABLE_KEY=

# ── S3 bucket (MediaConvert output — same assets as R2 in production) ───────
S3_BUCKET_NAME=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional custom endpoint (MinIO, etc.)
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=1

# ── Cloudflare D1 sync (pull snapshot every 5 minutes) ──────────────────────
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_D1_DATABASE_ID=e4e14e46-fcf2-4eb4-9eda-accf732c44f8

# ── Optional R2 → S3 manifest sync (m3u8 only) ───────────────────────────────
# R2_S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=vmp-videos

# ── MediaConvert vars (optional, if admin transcode UI is used) ─────────────
MEDIA_CONVERT_ENABLED=0
MEDIA_CONVERT_INPUT_PREFIX=mediaconvert-input
MEDIA_CONVERT_OUTPUT_PREFIX=mediaconvert-output
MEDIA_CONVERT_MAX_UPLOAD_MB=4096
MEDIA_CONVERT_PRICE_HD_PER_MIN=0.015
