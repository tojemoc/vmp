VMP_ENV=staging

# Frontend deploy tier for admin build footer (staging shows git commit; production shows semver tag).
# NUXT_PUBLIC_DEPLOY_TIER=staging
# NUXT_PUBLIC_GIT_COMMIT=local-dev-sha
# NUXT_PUBLIC_APP_VERSION=1.0.0-pre.1

# Shared
API_URL=http://localhost:8787
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
R2_BASE_URL=https://example-r2-domain/videos

# Frontend UI locale for this deployment (`en`, `sk`, or `cs`). One language per VMP instance.
# NUXT_PUBLIC_UI_LOCALE=en

# Sentry (DSNs are public; auth token is secret — set in CI for source map uploads)
NUXT_PUBLIC_SENTRY_DSN=replace_with_sentry_frontend_dsn
# NUXT_PUBLIC_SENTRY_ENVIRONMENT=production
# NUXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# NUXT_PUBLIC_SENTRY_ENABLE_LOGS=false
SENTRY_AUTH_TOKEN=replace_with_sentry_auth_token

# API secrets (set real values in CI / Wrangler secrets for deployed envs)
BREVO_API_KEY=replace_with_brevo_key
JWT_SECRET=replace_with_32_plus_characters
SENTRY_DSN=replace_with_sentry_worker_dsn
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENABLE_LOGS=false
RSS_SECRET=replace_with_32_plus_characters

# Datadog direct log shipping from the API Worker (optional; off unless DD_LOGS_ENABLED=true).
# Do not commit DD_API_KEY here — set secrets via:
#   production/staging: cd packages/api && npx wrangler secret put DD_API_KEY
#   local API dev:      packages/api/.dev.vars (gitignored)
# Non-secret toggles/tags can also live in packages/api/.dev.vars or Worker vars.
# DD_LOGS_ENABLED=true
# DD_SITE=datadoghq.eu
# DD_SERVICE=vmp-api
# DD_ENV=staging
# DD_VERSION=d1b5d04
STRIPE_SECRET_KEY=replace_with_stripe_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret
TOTP_ENCRYPTION_KEY=replace_with_32_plus_characters
VAPID_PUBLIC_KEY=replace_with_vapid_public
VAPID_PRIVATE_KEY=replace_with_vapid_private

# External API key used by /api/pills/update.
# Runtime first checks env.PILLS_API_KEY and falls back to admin_settings.pills_api_key.
PILLS_API_KEY=replace_with_pills_api_key
